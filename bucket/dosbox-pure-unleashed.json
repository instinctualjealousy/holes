    "bin": "DOSBoxPure.exe",
    "pre_install": [
        "if (!(Test-Path \"$persist_dir/DOSBoxPure.cfg\")) { New-Item -Path \"$persist_dir/DOSBoxPure.cfg\" -ItemType File | Out-Null }",
        "if (!(Test-Path \"$persist_dir/saves\")) { New-Item -Path \"$persist_dir/saves\" -ItemType Directory | Out-Null }",
        "if (!(Test-Path \"$persist_dir/system\")) { New-Item -Path \"$persist_dir/system\" -ItemType Directory | Out-Null }",
        "if (!(Test-Path \"$persist_dir/cache\")) { New-Item -Path \"$persist_dir/cache\" -ItemType Directory | Out-Null }"
    ],
    "persist": [
        "DOSBoxPure.cfg",
        "saves",
        "system",
        "cache"
    ],
    "checkver": {
        "url": "https://github.com/schellingb/dosbox-pure-unleashed/releases",
        "regex": "tag/([\\w.-]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/schellingb/dosbox-pure-unleashed/releases/download/$version/dosbox_pure_unleashed-windows-64bit-$(version)fix.zip"
